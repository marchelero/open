{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "build",
    "share": "manual",
    "autoupdate": "notify",
    "snapshot": true,
    "instructions": [
        ".opencode/instructions/INSTRUCTIONS.md",
        "AGENTS.md"
    ],
    "permission": {
        "skill": "allow",
        "read": "allow",
        "list": "allow",
        "glob": "allow",
        "grep": "allow"
    },
    "mcp": {
        "context7": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@upstash/context7-mcp"
            ]
        },
        "playwright": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@playwright/mcp"
            ]
        }
    },
    "plugin": [
        "opencode-dynamic-context-pruning",
        "opencode-skillful",
        "opencode-vibeguard",
        "opencode-pty"
    ]
}
