{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "build",
    "share": "manual",
    "autoupdate": "notify",
    "snapshot": true,
    "instructions": [
        "instructions/INSTRUCTIONS.md",
        "AGENTS.md",
        ".opencode/skills/api-design/SKILL.md",
        ".opencode/skills/security-review/SKILL.md",
        ".opencode/skills/tdd-workflow/SKILL.md",
        ".opencode/skills/verification-loop/SKILL.md",
        ".opencode/skills/error-handling/SKILL.md",
        ".opencode/skills/coding-standards/SKILL.md",
        ".opencode/skills/git-workflow/SKILL.md",
        ".opencode/skills/intent-driven-development/SKILL.md",
        ".opencode/skills/documentation-lookup/SKILL.md",
        ".opencode/skills/mcp-server-patterns/SKILL.md"
    ],
    "permission": {
        "skill": "allow"
    },
    "mcp": {
        "context7": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@upstash/context7-mcp"
            ]
        },
        "playwright": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "@playwright/mcp"
            ]
        }
    },
    "plugin": [
        "opencode-dynamic-context-pruning",
        "opencode-skillful",
        "opencode-vibeguard",
        "opencode-pty"
    ]
}
